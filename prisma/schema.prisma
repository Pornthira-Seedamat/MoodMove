// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        String          @id @default(cuid())
  username  String
  email     String          @unique
  password  String
  tasks     Task[]
  histories StatusHistory[]
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  level     Int      // เก็บระดับอารมณ์ 1-5
  createdAt DateTime @default(now())
  
  userId    String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StatusHistory {
  id             String   @id @default(cuid())
  userId         String
  moodKey        String   // เช่น angry, happy, tired
  moodLevel      Int      // ระดับ 1-5
  stepsCompleted Json     // เก็บสถานะการทำท่าต่างๆ
  day            Int      // สำหรับทำสถิติรายเดือน
  createdAt      DateTime @default(now())
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}