generator client {
  provider = "prisma-client-js"
}

// แก้ไขบรรทัดที่ 6 และ 7 ให้เป็นแบบนี้เป๊ะๆ ครับ
datasource db {
  provider = "postgresql"
  url      = "postgres://6c25bd074d2bd9e1d9748c7eead1c1f05311feeda99b62c362dacbf37578dc76:sk_mH7u_ZrG7BLz5rjl1eUTo@db.prisma.io:5432/postgres?sslmode=require&pool=true"
}

model User {
  id        String          @id @default(cuid())
  username  String
  email     String          @unique // ใช้สำหรับ Login และป้องกันอีเมลซ้ำ
  password  String
  
  // ความสัมพันธ์กับข้อมูลอื่นๆ
  tasks     Task[]
  histories StatusHistory[]
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  level     Int      // เก็บระดับอารมณ์ 1-5
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model StatusHistory {
  id             String   @id @default(cuid())
  userId         String
  moodKey        String   // เช่น angry, happy, tired
  moodLevel      Int      // ระดับ 1-5
  stepsCompleted Json     // เก็บสถานะการทำท่าต่างๆ เช่น { "0": true, "1": false }
  day            Int      // เก็บวันที่ 1-31 สำหรับทำสถิติรายเดือน
  createdAt      DateTime @default(now())
  
  user           User     @relation(fields: [userId], references: [id])
}